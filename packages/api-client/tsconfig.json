{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@zhiyu/shared-types": ["../shared-types/src/index.ts"],
      "@zhiyu/shared-types/*": ["../shared-types/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
